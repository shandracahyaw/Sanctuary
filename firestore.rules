rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorizedEmail() {
      return isSignedIn() && request.auth.token.email == 'shandracahya27@gmail.com' && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      // Allow if it's the specific authorized Google user
      // OR if it's the specific unauthorized but "allowed" manual session (for local persistence)
      return isAuthorizedEmail() || (request.auth == null && (userId == 'SHANDRA' || userId == 'escewescw')); 
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validators ---
    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.nim is string && data.nim.size() <= 20 &&
             data.faculty is string && data.faculty.size() <= 100 &&
             data.programStudy is string && data.programStudy.size() <= 100 &&
             data.username is string && data.username.size() <= 50 &&
             data.semester is number && data.semester >= 1 && data.semester <= 14 &&
             data.status in ['Aktif', 'Cuti', 'Non-Aktif'] &&
             (!('password' in data) || (data.password is string && data.password.size() <= 100)) &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000000)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidCourse(data) {
      return data.category in ['Non BPro', 'BPro', 'TAP (Tugas Akhir Program)'] &&
             data.code is string && data.code.size() <= 20 &&
             data.name is string && data.name.size() <= 200 &&
             data.sks is number && data.sks >= 0 && data.sks <= 12 &&
             data.lecturer is string && data.lecturer.size() <= 100 &&
             data.semester is number && data.semester >= 1 && data.semester <= 8 &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidEvaluation(data) {
      return data.session is number && data.session >= 1 && data.session <= 16 &&
             data.type in ['Kehadiran', 'Tugas / Tuton', 'TMK'] &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidGrade(data) {
      return data.courseId is string && data.courseId.size() <= 64 &&
             data.courseName is string && data.courseName.size() <= 200 &&
             data.semester is number && data.semester >= 1 && data.semester <= 8 &&
             data.gradeSymbol is string && data.gradeSymbol.size() <= 5 &&
             data.gradeValue is number && data.gradeValue >= 0 && data.gradeValue <= 4 &&
             data.totalMutu is number &&
             data.remarks in ['Lulus (LL)', 'Tidak Lulus (TL)'] &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // --- Matchers ---

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                      incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      (!('createdAt' in incoming()) || incoming().createdAt == existing().createdAt) &&
                      incoming().updatedAt == request.time;
    }

    // Course subcollection patterns (restricted)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Explicit subcollections
    match /users/{userId}/courses/{courseId} {
      allow list, get, create, update, delete: if isOwner(userId);
    }

    // Evaluations subcollection
    match /users/{userId}/courses/{courseId}/evaluations/{evalId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isValidId(evalId) &&
                      isValidEvaluation(incoming()) &&
                      incoming().keys().size() == 5 &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && 
                      isValidEvaluation(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time;
      allow delete: if isOwner(userId);
    }

    // Grades subcollection
    match /users/{userId}/grades/{gradeId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isValidId(gradeId) &&
                      isValidGrade(incoming()) &&
                      incoming().keys().size() == 9 &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && 
                      isValidGrade(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time;
      allow delete: if isOwner(userId);
    }
  }
}
